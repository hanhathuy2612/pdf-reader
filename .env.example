# Ollama (chỉ dùng khi KHÔNG set OPENAI_API_KEY)
OLLAMA_BASE_URL=http://localhost:11434

# Gemini — để trống khi dùng LM Studio / OpenAI
LANGEXTRACT_API_KEY=

# LM Studio: copy CHÍNH XÁC model id trong tab Local Server (có thể khác ví dụ bên dưới)
OPENAI_API_KEY=lm-studio
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
MODEL_ID=qwen2.5-14b-instruct-1m

# API server
HOST=0.0.0.0
PORT=8000
DEBUG=1
# Optional: set to 1 or true for development auto-reload (do not use in production).
# RELOAD=0

# 1000 dễ bị chunk nhỏ / extraction lỗi; 4000 khớp default trong code
MAX_CHAR_BUFFER=4000

# LM Studio tuning: ưu tiên model reasoning hơn rule
DIRECT_OPENAI_SCHEMA=1
EXTRACTION_TEXT_MODE=full
DETERMINISTIC_ENRICH=0
POST_CLEANUP=0
LOCAL_MAX_CHAR_BUFFER=4000
LOCAL_BATCH_LENGTH=1
LOCAL_MAX_WORKERS=1
LOCAL_MAX_OUTPUT_TOKENS=2000
EXTRACTION_PASSES=1