# --- Extraction backend: API key OR local Ollama ---
# If OPENAI_API_KEY or LANGEXTRACT_API_KEY is set, that provider is used; otherwise Ollama is used.

# Google Gemini (optional): set to use Gemini instead of Ollama. Get key from https://aistudio.google.com/
# LANGEXTRACT_API_KEY=your-gemini-api-key

# OpenAI (optional): set to use OpenAI instead of Ollama. Requires pip install langextract[openai].
# OPENAI_API_KEY=sk-your-openai-api-key

# --- Ollama (when no API key is set) ---
# Ollama API base URL (must be reachable from the API process).
# - With docker-compose: use http://ollama:11434
# - With Docker run (Ollama on host): use http://host.docker.internal:11434 (Windows/Mac) or host IP on Linux
# - Local run: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Model to use for extraction. Depends on provider:
# - Ollama: must be pulled (e.g. llama3.2). Default: llama3.2
# - Gemini: e.g. gemini-2.5-flash (default)
# - OpenAI: e.g. gpt-4o (default)
MODEL_ID=llama3.2

# Max characters per chunk when LangExtract splits long text. Larger = fewer chunks; reduces
# "Content must contain an extractions key" when a chunk has no entities. Default 4000 (LangExtract default is 1000).
# MAX_CHAR_BUFFER=4000

# --- API server ---
HOST=0.0.0.0
PORT=8000

# Optional: set to 1 or true for development auto-reload (do not use in production).
# RELOAD=0

# Debug logging: set to 1 or true to enable LangExtract and app debug logs (noisy).
# DEBUG=0
